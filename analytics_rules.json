{
  "rules": {
    ".read": false,
    "hourly": {
      ".read": true,
      "$hour": {
        ".write": true,
        ".validate": "newData.hasChildren() && (!newData.hasChild('swipes') || newData.child('swipes').isNumber()) && (!newData.hasChild('sessions') || newData.child('sessions').isNumber()) && (!newData.hasChild('time_sec') || newData.child('time_sec').isNumber())"
      }
    }
  }
}
